    "skf=StratifiedKFold(n_splits=5,shuffle=True,random_state=42)\n",
    "best = study.best_params\n",
    "\n",
    "# =============================================\n",
    "# MODEL 1: TUNED LIGHTGBM (using Optuna's best params)\n",
    "# =============================================\n",
    "oof_lgb = np.zeros(len(X))\n",
    "test_lgb = np.zeros(len(X_test))\n",
    "\n",
    "print(\"Training LightGBM (tuned)...\")\n",
    "for fold, (train_idx, val_idx) in enumerate(skf.split(X, y)):\n",
    "    model = lgb.LGBMClassifier(\n",
    "        objective=\"binary\", metric=\"auc\", verbosity=-1,\n",
    "        n_estimators=2000, random_state=42, **best\n",
    "    )\n",
    "    model.fit(\n",
    "        X.iloc[train_idx], y.iloc[train_idx],\n",
    "        eval_set=[(X.iloc[val_idx], y.iloc[val_idx])],\n",
    "        callbacks=[lgb.early_stopping(50), lgb.log_evaluation(0)]\n",
    "    )\n",
    "    oof_lgb[val_idx] = model.predict_proba(X.iloc[val_idx])[:, 1]\n",
    "    test_lgb += model.predict_proba(X_test)[:, 1] / 5\n",
    "    print(f\"  Fold {fold+1}: AUC = {roc_auc_score(y.iloc[val_idx], oof_lgb[val_idx]):.5f}\")\n",
    "print(f\"  LightGBM CV AUC: {roc_auc_score(y, oof_lgb):.5f}\\n\")\n",
    "\n",
    "# =============================================\n",
    "# MODEL 2: XGBOOST\n",
    "# =============================================\n",
    "oof_xgb = np.zeros(len(X))\n",
    "test_xgb = np.zeros(len(X_test))\n",
    "\n",
    "print(\"Training XGBoost...\")\n",
    "for fold, (train_idx, val_idx) in enumerate(skf.split(X, y)):\n",
    "    model = xgb.XGBClassifier(\n",
    "        objective=\"binary:logistic\", eval_metric=\"auc\",\n",
    "        n_estimators=2000, learning_rate=0.03,\n",
    "        max_depth=5, subsample=0.9, colsample_bytree=0.58,\n",
    "        reg_alpha=0.55, reg_lambda=8.7, min_child_weight=90,\n",
    "        random_state=42, verbosity=0, tree_method=\"hist\",\n",
    "        early_stopping_rounds=50\n",
    "    )\n",
    "    model.fit(\n",
    "        X.iloc[train_idx], y.iloc[train_idx],\n",
    "        eval_set=[(X.iloc[val_idx], y.iloc[val_idx])],\n",
    "        verbose=0\n",
    "    )\n",
    "    oof_xgb[val_idx] = model.predict_proba(X.iloc[val_idx])[:, 1]\n",
    "    test_xgb += model.predict_proba(X_test)[:, 1] / 5\n",
    "    print(f\"  Fold {fold+1}: AUC = {roc_auc_score(y.iloc[val_idx], oof_xgb[val_idx]):.5f}\")\n",
    "print(f\"  XGBoost CV AUC: {roc_auc_score(y, oof_xgb):.5f}\\n\")\n",
    "\n",
    "# =============================================\n",
    "# MODEL 3: CATBOOST\n",
    "# =============================================\n",
    "oof_cat = np.zeros(len(X))\n",
    "test_cat = np.zeros(len(X_test))\n",
    "\n",
    "print(\"Training CatBoost...\")\n",
    "for fold, (train_idx, val_idx) in enumerate(skf.split(X, y)):\n",
    "    model = CatBoostClassifier(\n",
    "        iterations=2000, learning_rate=0.03, depth=5,\n",
    "        eval_metric=\"AUC\", random_seed=42, verbose=0,\n",
    "        early_stopping_rounds=50, l2_leaf_reg=8.7,\n",
    "    )\n",
    "    model.fit(\n",
    "        X.iloc[train_idx], y.iloc[train_idx],\n",
    "        eval_set=(X.iloc[val_idx], y.iloc[val_idx])\n",
    "    )\n",
    "    oof_cat[val_idx] = model.predict_proba(X.iloc[val_idx])[:, 1]\n",
    "    test_cat += model.predict_proba(X_test)[:, 1] / 5\n",
