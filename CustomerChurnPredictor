   "source": [
    "best_auc = 0\n",
    "best_w = (0, 0, 0)\n",
    "\n",
    "for w_lgb in np.arange(0.20, 0.55, 0.05):\n",
    "    for w_xgb in np.arange(0.20, 0.55, 0.05):\n",
    "        w_cat = round(1.0 - w_lgb - w_xgb, 2)\n",
    "        if w_cat < 0.10 or w_cat > 0.55:\n",
    "            continue\n",
    "        blend = w_lgb * oof_lgb_all + w_xgb * oof_xgb_all + w_cat * oof_cat_all\n",
    "        auc = roc_auc_score(y, blend)\n",
    "        if auc > best_auc:\n",
    "            best_auc = auc\n",
    "            best_w = (w_lgb, w_xgb, w_cat)\n",
    "\n",
    "print(f\"Best blend weights: LGB={best_w[0]:.2f}, XGB={best_w[1]:.2f}, CAT={best_w[2]:.2f}\")\n",
    "print(f\"Best blend CV AUC:  {best_auc:.5f}\")\n",
    "\n",
    "final_preds = best_w[0] * test_lgb_all + best_w[1] * test_xgb_all + best_w[2] * test_cat_all"
   ]
