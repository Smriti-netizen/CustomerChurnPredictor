    "\n",
    "\n",
    "test_ids = test[\"id\"]\n",
    "\n",
    "original = pd.read_csv(\"/kaggle/input/datasets/blastchar/telco-customer-churn/WA_Fn-UseC_-Telco-Customer-Churn.csv\")\n",
    "original = original.drop(columns=[\"customerID\"])\n",
    "original[\"Churn\"] = original[\"Churn\"].map({\"Yes\": 1, \"No\": 0})\n",
    "original[\"TotalCharges\"] = pd.to_numeric(original[\"TotalCharges\"], errors=\"coerce\").fillna(0)\n",
    "print(f\"Original dataset: {len(original)} rows — used for stats only, NOT merged\")\n",
    "\n",
    "cat_cols_raw = [\"gender\", \"Partner\", \"Dependents\", \"PhoneService\", \"MultipleLines\",\n",
    "                \"InternetService\", \"OnlineSecurity\", \"OnlineBackup\", \"DeviceProtection\",\n",
    "                \"TechSupport\", \"StreamingTV\", \"StreamingMovies\", \"Contract\",\n",
    "                \"PaperlessBilling\", \"PaymentMethod\"]\n",
    "\n",
    "orig_churn_mean = original[\"Churn\"].mean()\n",
    "orig_stats_map = {}\n",
    "for col in cat_cols_raw:\n",
    "    if col in original.columns:\n",
    "        orig_stats_map[col] = original.groupby(col)[\"Churn\"].mean().to_dict()\n",
    "\n",
    "def engineer_features(df, orig_stats=None):\n",
    "    df = df.copy()\n",
    "    df[\"TotalCharges\"] = pd.to_numeric(df[\"TotalCharges\"], errors=\"coerce\").fillna(0)\n",
    "\n",
    "    df[\"AvgMonthlyCharge\"] = df[\"TotalCharges\"] / df[\"tenure\"].clip(lower=1)\n",
    "    df[\"ChargeDiff\"] = df[\"MonthlyCharges\"] - df[\"AvgMonthlyCharge\"]\n",
    "    df[\"tenure_x_charges\"] = df[\"tenure\"] * df[\"MonthlyCharges\"]\n",
    "\n",
    "    service_cols = [\"OnlineSecurity\", \"OnlineBackup\", \"DeviceProtection\",\n",
    "                    \"TechSupport\", \"StreamingTV\", \"StreamingMovies\"]\n",
    "    df[\"NumServices\"] = sum((df[c] == \"Yes\").astype(int) for c in service_cols)\n",
    "\n",
    "    if orig_stats:\n",
    "        for col, mapping in orig_stats.items():\n",
    "            if col in df.columns:\n",
    "                df[f\"ORIG_{col}_churnrate\"] = df[col].map(mapping).fillna(orig_churn_mean)\n",
    "\n",
    "    return df\n",
    "\n",
    "train = engineer_features(train, orig_stats_map)\n",
    "test = engineer_features(test, orig_stats_map)\n",
    "\n",
    "train[\"Churn\"] = train[\"Churn\"].map({\"Yes\": 1, \"No\": 0}).fillna(train[\"Churn\"])\n",
    "train[\"Churn\"] = pd.to_numeric(train[\"Churn\"], errors=\"coerce\")\n",
    "train = train.dropna(subset=[\"Churn\"])\n",
    "train[\"Churn\"] = train[\"Churn\"].astype(int)\n",
    "\n",
    "cat_cols = train.select_dtypes(include=\"object\").columns.tolist()\n",
    "for col in cat_cols:\n",
    "    le = LabelEncoder()\n",
    "    le.fit(pd.concat([train[col], test[col]]).astype(str))\n",
    "    train[col] = le.transform(train[col].astype(str))\n",
    "    test[col] = le.transform(test[col].astype(str))\n",
    "\n",
    "feature_cols = [c for c in train.columns if c not in [\"id\", \"Churn\"]]\n",
    "X = train[feature_cols]\n",
    "y = train[\"Churn\"]\n",
    "X_test = test[feature_cols]\n",
    "\n",
    "print(f\"\\n{len(feature_cols)} features\")\n",
    "print(f\"Train size: {len(X)} rows\")\n",
    "print(f\"Churn rate: {y.mean():.3f}\")"
   ]
