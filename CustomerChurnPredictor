    "test_ids = test[\"id\"]\n",
    "\n",
    "original = pd.read_csv(\"/kaggle/input/datasets/blastchar/telco-customer-churn/WA_Fn-UseC_-Telco-Customer-Churn.csv\")\n",
    "original = original.drop(columns=[\"customerID\"])\n",
    "original[\"id\"] = range(900000, 900000 + len(original))\n",
    "print(f\"Original dataset: {len(original)} rows\")\n",
    "print(f\"Original Churn values: {original['Churn'].unique()}\")\n",
    "\n",
    "common_cols = [c for c in train.columns if c in original.columns]\n",
    "original = original[common_cols]\n",
    "print(f\"Train before merge: {len(train)} rows\")\n",
    "train = pd.concat([train, original], ignore_index=True)\n",
    "print(f\"Train after merge:  {len(train)} rows\")\n",
    "\n",
    "def engineer_features(df):\n",
    "    df = df.copy()\n",
    "    df[\"TotalCharges\"] = pd.to_numeric(df[\"TotalCharges\"], errors=\"coerce\").fillna(0)\n",
    "    df[\"AvgMonthlyCharge\"] = df[\"TotalCharges\"] / df[\"tenure\"].clip(lower=1)\n",
    "    df[\"ChargeDiff\"] = df[\"MonthlyCharges\"] - df[\"AvgMonthlyCharge\"]\n",
    "    df[\"tenure_group\"] = pd.cut(df[\"tenure\"], bins=[-1,6,12,24,48,60,999], labels=[0,1,2,3,4,5]).astype(int)\n",
    "    service_cols = [\"OnlineSecurity\",\"OnlineBackup\",\"DeviceProtection\",\"TechSupport\",\"StreamingTV\",\"StreamingMovies\"]\n",
    "    df[\"NumServices\"] = sum((df[c] == \"Yes\").astype(int) for c in service_cols)\n",
    "    df[\"ChargePerService\"] = df[\"MonthlyCharges\"] / df[\"NumServices\"].clip(lower=1)\n",
    "    df[\"HasInternet\"] = (df[\"InternetService\"] != \"No\").astype(int)\n",
    "    df[\"NewMonthToMonth\"] = ((df[\"tenure\"] <= 12) & (df[\"Contract\"] == \"Month-to-month\")).astype(int)\n",
    "    df[\"HasProtection\"] = ((df[\"OnlineSecurity\"]==\"Yes\")|(df[\"OnlineBackup\"]==\"Yes\")|(df[\"DeviceProtection\"]==\"Yes\")|(df[\"TechSupport\"]==\"Yes\")).astype(int)\n",
    "    df[\"tenure_x_charges\"] = df[\"tenure\"] * df[\"MonthlyCharges\"]\n",
    "    df[\"IsSolo\"] = ((df[\"Partner\"] == \"No\") & (df[\"Dependents\"] == \"No\")).astype(int)\n",
    "    return df\n",
    "\n",
    "train = engineer_features(train)\n",
    "test = engineer_features(test)\n",
    "\n",
    "train[\"Churn\"] = train[\"Churn\"].replace({\"Yes\": 1, \"No\": 0, True: 1, False: 0})\n",
    "train[\"Churn\"] = pd.to_numeric(train[\"Churn\"], errors=\"coerce\")\n",
    "train = train.dropna(subset=[\"Churn\"])\n",
    "train[\"Churn\"] = train[\"Churn\"].astype(int)\n",
    "\n",
    "cat_cols = train.select_dtypes(include=\"object\").columns.tolist()\n",
    "for col in cat_cols:\n",
    "    le = LabelEncoder()\n",
    "    le.fit(pd.concat([train[col], test[col]]).astype(str))\n",
    "    train[col] = le.transform(train[col].astype(str))\n",
    "    test[col] = le.transform(test[col].astype(str))\n",
    "\n",
    "feature_cols = [c for c in train.columns if c not in [\"id\", \"Churn\"]]\n",
    "X = train[feature_cols]\n",
    "y = train[\"Churn\"]\n",
    "X_test = test[feature_cols]\n",
    "\n",
    "print(f\"\\n{len(feature_cols)} features\")\n",
    "print(f\"Train size: {len(X)} rows\")\n",
    "print(f\"Churn rate: {y.mean():.3f}\")"
   ]
