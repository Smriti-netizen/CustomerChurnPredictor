    "test_ids=test[\"id\"]\n",
    "\n",
    "train[\"TotalCharges\"]=pd.to_numeric(train[\"TotalCharges\"],errors=\"coerce\").fillna(0)\n",
    "test[\"TotalCharges\"]=pd.to_numeric(train[\"TotalCharges\"],errors=\"coerce\").fillna(0)\n",
    "\n",
    "train[\"Churn\"]=(train[\"Churn\"]=='Yes').astype(int)\n",
    "\n",
    "cat_cols=train.select_dtypes(include=\"object\").columns.tolist() #select text/non numbered columns\n",
    "print(f\"Categorical columns to encode:{cat_cols}\")\n",
    "\n",
    "for x in cat_cols:\n",
    "    le=LabelEncoder()\n",
    "    le.fit(pd.concat([train[x],test[x]]).astype(str))\n",
    "    train[x]=le.transform(train[x].astype(str))\n",
    "    test[x]=le.transform(test[x].astype(str))\n",
    "\n",
    "feature_cols=[c for c in train.columns if c not in [\"id\",\"Churn\"]]\n",
    "X=train[feature_cols]\n",
    "y=train[\"Churn\"]\n",
    "X_test=test[feature_cols]\n",
    "\n",
    "print(f\"\\n{len(feature_cols)} features:{feature_cols}\")\n",
    "\n",
